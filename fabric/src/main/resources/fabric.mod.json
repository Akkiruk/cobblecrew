{
  "schemaVersion": 1,
  "id": "cobblecrew",
  "version": "${version}",
  "name": "CobbleCrew",
  "description": "Put your Pokémon to work — in the pasture AND by your side. 92+ jobs across 9 categories, with party Pokémon support.",
  "authors": [
    "Akkiruk",
    "Accieo"
  ],
  "contact": {
    "issues": "https://github.com/Akkiruk/cobblecrew/issues",
    "sources": "https://github.com/Akkiruk/cobblecrew"
  },
  "license": "MPL-2.0",
  "icon": "assets/cobblecrew/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "akkiruk.cobblecrew.fabric.CobbleCrewFabric",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "akkiruk.cobblecrew.fabric.client.CobbleCrewFabricClient",
        "adapter": "kotlin"
      }
    ],
    "modmenu": [
      {
        "value": "akkiruk.cobblecrew.fabric.client.config.CobbleCrewModMenu",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "cobblecrew.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.14",
    "fabric-language-kotlin": "*",
    "minecraft": "~1.21.1",
    "java": ">=21"
  },
  "suggests": {
    "another-mod": "*"
  }
}
